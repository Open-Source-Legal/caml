{
  "name": "@os-legal/caml",
  "version": "0.1.0",
  "type": "module",
  "description": "CAML (Corpus Article Markup Language) parser — zero-dependency markdown superset for legal articles",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Open-Source-Legal/caml.git",
    "directory": "packages/caml"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
